---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	noindex?: boolean;
}

const SITE_URL = 'https://equarion.hu';
const defaultTitle = 'Equarion Lovarda | Piliscsév';
const defaultDescription =
	'Lovasoktatás, nyári táborok, tereplovaglás és családias lovarda Piliscséven.';
const {
	title = defaultTitle,
	description = defaultDescription,
	image = '/images/hero.JPG',
	noindex = false,
} = Astro.props;

const navigationItems = [
	{ href: '/lovaink', label: 'Lovaink' },
	{ href: '/taborok', label: 'Táborok' },
	{ href: '/rolunk', label: 'Rólunk' },
	{ href: '/galeria', label: 'Galéria' },
	{ href: '/kapcsolat', label: 'Kapcsolat' },
];

const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const socialImageUrl = new URL(image, SITE_URL).toString();
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'SportsActivityLocation',
	name: 'Equarion Lovarda',
	description,
	url: SITE_URL,
	image: socialImageUrl,
	telephone: '+36703389049',
	email: 'info@equarion.hu',
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Béke utca 145.',
		addressLocality: 'Piliscsév',
		postalCode: '2519',
		addressCountry: 'HU',
	},
	sameAs: [
		'https://www.instagram.com/babagergely/',
		'https://www.facebook.com/profile.php?id=100004151898671&locale=hu_HU',
		'https://www.tiktok.com/@gergelybaba?lang=hu-HU',
	],
};
---

<!doctype html>
<html lang="hu">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="512x512" href="/images/kislogo.png" />
		<link rel="apple-touch-icon" href="/images/kislogo.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<meta name="theme-color" content="#1F4D3A" />
		<meta name="keywords" content="Equarion Lovarda, lovasoktatás, lovastábor, tereplovaglás, lókiképzés, Piliscsév, lovarda" />
		<link rel="canonical" href={canonicalUrl} />
		<title>{title}</title>
		<meta property="og:site_name" content="Equarion Lovarda" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:locale" content="hu_HU" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-equi-beige text-equi-black antialiased">
		<div class="relative flex min-h-screen flex-col overflow-x-hidden">
			<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(139,107,74,0.14),_transparent_38%),linear-gradient(180deg,_rgba(250,250,247,0.9),_rgba(243,239,231,1))]"></div>

			<header id="site-header" class="fixed inset-x-0 top-0 z-50 bg-equi-beige/95 shadow-[0_12px_35px_rgba(34,34,34,0.06)] backdrop-blur-md transition-transform duration-300 ease-out">
				<nav class="mx-auto flex w-full max-w-7xl items-center justify-between px-5 py-3 sm:px-6 lg:px-8">
					<a href="/" class="flex items-center gap-3">
						<img
							src="/images/fologo.svg"
							alt="Equarion Lovarda"
							class="h-9 w-auto sm:h-10"
						/>
					</a>

					<ul class="hidden items-center gap-2 lg:flex">
						{
							navigationItems.map((item) => {
								const isActive = currentPath === item.href;

								return (
									<li>
										<a
											href={item.href}
											class:list={[
												'rounded-full px-4 py-2 text-sm font-medium transition duration-200',
												isActive
													? 'bg-equi-green text-equi-white shadow-lg shadow-equi-green/20'
													: 'text-equi-black hover:bg-equi-white hover:text-equi-green',
											]}
										>
											{item.label}
										</a>
									</li>
								);
							})
						}
					</ul>

					<details class="group relative lg:hidden">
						<summary class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-equi-brown/30 bg-equi-white px-4 py-2 text-sm font-medium text-equi-black shadow-sm marker:content-none">
							<span>Menü</span>
							<span class="text-equi-brown transition group-open:rotate-45">+</span>
						</summary>
						<div class="absolute right-0 top-full mt-3 w-64 overflow-hidden rounded-3xl border border-equi-brown/20 bg-equi-white p-3 shadow-2xl shadow-equi-black/10">
							<ul class="space-y-1">
								{
									navigationItems.map((item) => {
										const isActive = currentPath === item.href;

										return (
											<li>
												<a
													href={item.href}
													class:list={[
														'block rounded-2xl px-4 py-3 text-sm font-medium transition',
														isActive
															? 'bg-equi-green text-equi-white'
															: 'text-equi-black hover:bg-equi-beige',
													]}
												>
													{item.label}
												</a>
											</li>
										);
									})
								}
							</ul>
						</div>
					</details>
				</nav>
			</header>

			<main class="relative z-10 flex-1">
				<slot />
			</main>

			<footer class="relative z-10 mt-20 border-t border-equi-brown/20 bg-equi-green text-equi-white">
				<div class="mx-auto grid w-full max-w-7xl gap-10 px-5 py-12 sm:px-6 md:grid-cols-3 lg:px-8">
					<div>
						<h2 class="font-serif text-xl font-semibold">Kapcsolat</h2>
						<ul class="mt-4 space-y-2 text-sm text-equi-white/75">
							<li>+36 70 338 9049</li>
							<li>info@equarion.hu</li>
							<li>2519 Piliscsév, Béke utca 145.</li>
						</ul>
					</div>
					<div>
						<h2 class="font-serif text-xl font-semibold">Közösség</h2>
						<ul class="mt-4 space-y-2 text-sm text-equi-white/75">
							<li><a href="https://www.instagram.com/babagergely/" class="transition hover:text-equi-white">Instagram</a></li>
							<li><a href="https://www.facebook.com/profile.php?id=100004151898671&locale=hu_HU" class="transition hover:text-equi-white">Facebook</a></li>
							<li><a href="https://www.tiktok.com/@gergelybaba?lang=hu-HU" class="transition hover:text-equi-white">TikTok</a></li>
						</ul>
					</div>
					<div>
						<h2 class="font-serif text-xl font-semibold">Információ</h2>
						<ul class="mt-4 space-y-2 text-sm text-equi-white/75">
							<li><a href="/kapcsolat" class="transition hover:text-equi-white">Kapcsolat</a></li>
							<li><a href="/taborok" class="transition hover:text-equi-white">Nyári táborok</a></li>
							<li><a href="/lovaink" class="transition hover:text-equi-white">Lovaink</a></li>
						</ul>
					</div>
				</div>
			</footer>
		</div>
		<script>
			const header = document.querySelector('#site-header');
			let lastScrollY = window.scrollY;

			window.addEventListener(
				'scroll',
				() => {
					if (!header) return;

					const currentScrollY = window.scrollY;
					const isScrollingDown = currentScrollY > lastScrollY;
					const isPastHeader = currentScrollY > 120;

					header.classList.toggle('-translate-y-full', isScrollingDown && isPastHeader);
					header.classList.toggle('translate-y-0', !isScrollingDown || !isPastHeader);

					lastScrollY = currentScrollY;
				},
				{ passive: true },
			);
		</script>
	</body>
</html>
