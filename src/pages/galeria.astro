---

<Layout
	title="Galéria | Equarion Lovarda"
	description="Képek az Equarion Lovarda mindennapjaiból, lovainkról, táborainkról és közös lovas pillanatainkról."
	image="/images/gallery/IMG_6755.webp"
>
	<section class="page-section-top mx-auto w-full max-w-7xl px-5 pb-8 sm:px-6 lg:px-8">
		<p class="section-label">Galéria</p>
		<h1 class="mt-4 max-w-4xl text-5xl font-semibold text-equi-green sm:text-6xl">
			Képek a lovarda életéből, a lovakról és a kalandjainkról.
		</h1>
	</section>

	<section class="mx-auto w-full max-w-7xl px-5 py-6 sm:px-6 lg:px-8 lg:py-10">
		<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
			{
				images.map((src, index) => (
					<figure
						class:list={[
							'overflow-hidden rounded-[1.8rem] border border-equi-brown/15 bg-equi-white shadow-[0_20px_45px_rgba(34,34,34,0.06)]',
							index % 5 === 0 ? 'xl:col-span-2' : '',
						]}
					>
						<img
							src={src}
							alt={`Equarion galéria kép ${index + 1}`}
							loading="lazy"
							class="h-80 w-full object-cover transition duration-500 hover:scale-105"
						/>
					</figure>
				))
			}
		</div>
	</section>
</Layout>
