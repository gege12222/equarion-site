---
import Layout from '../layouts/Layout.astro';

const services = [
	{
		title: 'Lovasoktatás',
		description:
			'Kezdőtől a haladó szintig személyre szabott oktatás, fókuszban a biztos alapokkal.',
	},
	{
		title: 'Táborok',
		description:
			'Gyerekeknek szóló élménydús napközi és nyári táborok lovaglással, játékokkal és természetközeli programokkal.',
	},
	{
		title: 'Tereplovaglás',
		description:
			'Vezetett tereplovaglások erdei és mezei útvonalakon, kezdő és haladó lovasoknak egyaránt.',
	},
];

const galleryImages = [
	'/images/gallery/IMG_6755.webp',
	'/images/gallery/IMG_6617.webp',
	'/images/gallery/IMG_4380.webp',
	'/images/gallery/IMG_4131.webp',
	'/images/gallery/IMG_0540.webp',
	'/images/gallery/IMG_6675.webp',
];
---

<Layout
	title="Equarion Lovarda | Piliscsév"
	description="Lovasoktatás, nyári táborok, tereplovaglás és családias lovarda Piliscséven."
	image="/images/hero.JPG"
>
	<section class="relative isolate flex min-h-[88vh] items-center overflow-hidden">
		<img
			src="/images/hero.JPG"
			alt="Lovak a természetben"
			class="absolute inset-0 h-full w-full object-cover"
		/>
		<div class="absolute inset-0 bg-equi-green/75"></div>
		<div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(34,34,34,0.3),transparent_55%)]"></div>

		<div class="relative mx-auto flex w-full max-w-7xl px-5 py-24 sm:px-6 lg:px-8">
			<div class="max-w-3xl">
				<h1 class="mt-6 text-5xl font-semibold leading-none text-equi-white sm:text-6xl lg:flex lg:items-baseline lg:gap-6 lg:text-8xl">
					<span class="block">Equarion</span>
					<span class="hero-rotator mt-3 block h-[1.22em] overflow-hidden text-equi-beige sm:mt-4 lg:mt-0 lg:min-w-[6.6em]">
						<span class="hero-rotator-track block">
							<span class="hero-rotator-line">lovarda</span>
							<span class="hero-rotator-line">lovasoktatás</span>
							<span class="hero-rotator-line">lókiképzés</span>
							<span class="hero-rotator-line">terep­lovaglás</span>
							<span class="hero-rotator-line">lovarda</span>
						</span>
					</span>
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-8 text-equi-beige/90 sm:text-xl">
					Lovasoktatás, táborok és tereplovaglás a Pilis szívében.
				</p>
				<div class="mt-10 flex flex-col gap-4 sm:flex-row">
					<a
						href="/taborok"
						class="inline-flex items-center justify-center rounded-full bg-equi-white px-7 py-4 text-sm font-semibold text-equi-green transition hover:bg-equi-beige"
					>
						Táboraink
					</a>
					<a
						href="/kapcsolat"
						class="inline-flex items-center justify-center rounded-full border border-equi-white/40 px-7 py-4 text-sm font-semibold text-equi-white transition hover:bg-equi-white/10"
					>
						Kapcsolat
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="mx-auto grid w-full max-w-7xl gap-12 px-5 py-20 sm:px-6 lg:grid-cols-[1fr_1.1fr] lg:px-8 lg:py-24">
		<div class="order-2 lg:order-1">
			<p class="section-label">Kik vagyunk?</p>
			<h2 class="mt-4 text-4xl font-semibold text-equi-green sm:text-5xl">
				Egy hely, ahova jó megérkezni – és öröm visszatérni.
			</h2>
			<p class="mt-6 max-w-2xl text-base leading-8 text-equi-black/75">
				Az Equarion Lovarda Piliscséven, a Pilis ölelésében várja a lovak szerelmeseit. Nálunk a nyugodt környezet, a családias hangulat és a személyes figyelem legalább olyan fontos, mint maga a lovaglás. Hiszünk abban, hogy a lovakkal töltött idő feltölt, önbizalmat ad, és maradandó élményeket teremt – gyerekeknek és felnőtteknek egyaránt.
			</p>
			<a
				href="/rolunk"
				class="mt-8 inline-flex rounded-full border border-equi-brown px-6 py-3 text-sm font-semibold text-equi-brown transition hover:bg-equi-brown hover:text-equi-white"
			>
				Rólunk
			</a>
		</div>
		<div class="order-1 lg:order-2">
			<div class="overflow-hidden rounded-[2rem] border border-equi-brown/20 bg-equi-white p-3 shadow-[0_30px_70px_rgba(34,34,34,0.08)]">
				<img
					src="/images/horsesgroup.webp"
					alt="Lovas és ló az Equarion Lovardában"
					loading="lazy"
					class="h-[420px] w-full rounded-[1.4rem] object-cover"
				/>
			</div>
		</div>
	</section>

	<section class="mx-auto w-full max-w-7xl px-5 py-6 sm:px-6 lg:px-8 lg:py-10">
		<div class="rounded-[2.2rem] border border-equi-brown/15 bg-equi-white/90 px-6 py-10 shadow-[0_24px_60px_rgba(34,34,34,0.06)] sm:px-8 lg:px-12 lg:py-14">
			<div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
				<div class="max-w-2xl">
					<p class="section-label">Szolgáltatások</p>
					<h2 class="mt-4 text-4xl font-semibold text-equi-green sm:text-5xl">
						Mivel foglalkozunk?
					</h2>
				</div>
			</div>

			<div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
				{
					services.map((service) => (
						<article class="group rounded-[1.8rem] border border-equi-brown/20 bg-equi-beige p-8 transition hover:-translate-y-1 hover:bg-equi-white hover:shadow-[0_20px_50px_rgba(31,77,58,0.12)]">
							<div class="mb-6 h-px w-16 bg-equi-brown/50 transition group-hover:w-24"></div>
							<h3 class="text-3xl font-semibold text-equi-green">
								{service.title}
							</h3>
							<p class="mt-4 text-base leading-8 text-equi-black/70">
								{service.description}
							</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="mx-auto w-full max-w-7xl px-5 py-20 sm:px-6 lg:px-8 lg:py-24">
		<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
			<div>
				<p class="section-label">Mini Galéria</p>
				<h2 class="mt-4 text-4xl font-semibold text-equi-green sm:text-5xl">
					Hangulatok a mindennapjainkból
				</h2>
			</div>
			<a
				href="/galeria"
				class="inline-flex rounded-full border border-equi-brown px-6 py-3 text-sm font-semibold text-equi-brown transition hover:bg-equi-brown hover:text-equi-white"
			>
				Teljes galéria
			</a>
		</div>

		<div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{
				galleryImages.map((image, index) => (
					<figure class:list={[
						'overflow-hidden rounded-[1.75rem] border border-equi-brown/15 bg-equi-white shadow-[0_20px_45px_rgba(34,34,34,0.06)]',
						index === 0 || index === 3 ? 'sm:col-span-2 lg:col-span-1' : '',
					]}>
						<img
							src={image}
							alt={`Galéria kép ${index + 1}`}
							class="h-72 w-full object-cover transition duration-500 hover:scale-105"
						/>
					</figure>
				))
			}
		</div>
	</section>

	<section id="kapcsolat" class="mx-auto w-full max-w-7xl px-5 pb-20 sm:px-6 lg:px-8 lg:pb-24">
		<div class="rounded-[2rem] border border-equi-brown/20 bg-equi-white p-8 shadow-[0_20px_50px_rgba(34,34,34,0.05)] sm:p-10">
			<p class="section-label">Kapcsolat</p>
			<h2 class="mt-4 text-4xl font-semibold text-equi-green sm:text-5xl">
				Írj vagy hívj minket.
			</h2>
			<p class="mt-5 max-w-2xl text-base leading-8 text-equi-black/75">
				Ha kérdésed van lovasoktatással, bértartással vagy táborokkal kapcsolatban, keress minket e-mailben vagy telefonon.
			</p>
			<div class="mt-6 flex flex-col gap-3 text-lg font-semibold text-equi-green sm:flex-row sm:gap-8">
				<a href="mailto:info@equarion.hu" class="hover:text-equi-brown">info@equarion.hu</a>
				<a href="tel:+36703389049" class="hover:text-equi-brown">+36 70 338 9049</a>
			</div>
		</div>
	</section>
</Layout>
